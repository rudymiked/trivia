# Google Maps API Key (required for web)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# API URL (optional - defaults to localhost:7071 for local development)
EXPO_PUBLIC_API_URL=http://localhost:7071/api

# Google OAuth Client IDs (required for authentication)
# Create these at https://console.cloud.google.com/apis/credentials
# Expo Go client ID (usually same as WEB client for local development)
EXPO_PUBLIC_GOOGLE_CLIENT_ID_EXPO=your_expo_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=your_web_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=your_ios_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=your_android_client_id.apps.googleusercontent.com
