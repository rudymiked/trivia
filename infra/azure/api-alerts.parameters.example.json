{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "namePrefix": {
      "value": "pinpoint-api"
    },
    "location": {
      "value": "eastus"
    },
    "monitorScopeResourceId": {
      "value": "/subscriptions/<subscription-id>/resourceGroups/<resource-group>/providers/Microsoft.Insights/components/<app-insights-name>"
    },
    "monitorScopeType": {
      "value": "microsoft.insights/components"
    },
    "actionGroupResourceId": {
      "value": "/subscriptions/<subscription-id>/resourceGroups/<resource-group>/providers/microsoft.insights/actionGroups/<action-group-name>"
    },
    "roleName": {
      "value": "pinpoint-api"
    },
    "errorRateThresholdPct": {
      "value": 5
    },
    "minRequestsForRate": {
      "value": 20
    },
    "p95LatencyMs": {
      "value": 1200
    },
    "minRequestsForLatency": {
      "value": 20
    },
    "minCrashCount": {
      "value": 10
    },
    "crashSpikeMultiplier": {
      "value": 3
    }
  }
}
